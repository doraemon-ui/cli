{
  "compilerOptions": {
    "experimentalDecorators": true,
    "target": "esnext",
    "module": "commonjs",
    "allowJs": false,
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "moduleResolution": "bundler",
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "newLine": "lf",
    "lib": ["es2015", "es5"],
    "skipLibCheck": true
  },
  "compileOnSave": false,
  "exclude": ["node_modules/*", "miniprogram_dist/*", "templates/**"]
}
