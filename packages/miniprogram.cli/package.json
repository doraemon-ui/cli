{
  "name": "@doraemon-ui/miniprogram.cli",
  "private": false,
  "version": "0.0.2-alpha.50",
  "description": "Command line interface for rapid doraemon-ui development",
  "bin": {
    "dora": "./lib/bin/cli.js"
  },
  "author": "skyvow <724355924@qq.com>",
  "homepage": "",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "types/index.d.ts",
  "keywords": [
    "doraemon-ui",
    "miniprogram",
    "cli"
  ],
  "scripts": {
    "dev": "pnpm clean && pnpm build:dev",
    "build": "pnpm clean && pnpm build:lib",
    "build:dev": "cross-env tsc -p ./tsconfig.json --watch --incremental",
    "build:lib": "cross-env tsc -p ./tsconfig.json --declaration --declarationDir types",
    "clean": "cross-env rimraf lib/* types/*",
    "preversion": "pnpm build"
  },
  "dependencies": {
    "@doraemon-ui/miniprogram.tools": "workspace:*",
    "@types/minimist": "^1.2.5",
    "axios": "^1.15.0",
    "chalk": "^4.1.2",
    "command-exists": "^1.2.9",
    "commander": "^14.0.3",
    "cross-env": "^10.1.0",
    "find-parent-dir": "^0.3.1",
    "git-user-name": "^2.0.0",
    "inquirer": "^8.2.4",
    "lodash.defaultsdeep": "^4.6.1",
    "minimist": "^1.2.8",
    "ncp": "^2.0.0",
    "rimraf": "^6.1.3",
    "string.prototype.padend": "^3.1.6",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/command-exists": "^1.2.3",
    "@types/find-parent-dir": "^0.3.3",
    "@types/inquirer": "^8.2.1",
    "@types/node": "^25.5.2",
    "types-package-json": "^2.0.39"
  },
  "publishConfig": {
    "access": "public"
  }
}
