{
  "name": "template.miniprogram-component",
  "private": true,
  "version": "0.0.1-alpha.0",
  "description": "miniprogram component for doraemon-ui",
  "author": "skyvow <724355924@qq.com>",
  "homepage": "",
  "license": "MIT",
  "miniprogram": "miniprogram_dist",
  "main": "miniprogram_dist/index.js",
  "module": "miniprogram_dist/index.js",
  "devMain": "src/index.ts",
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "miniprogram_dist"
  ],
  "keywords": [
    "doraemon-ui"
  ],
  "scripts": {
    "serve": "dora serve ./playground --open --build-npm",
    "build:dev": "dora build --watch",
    "build": "dora build && pnpm build:dts",
    "build:dts": "cross-env NODE_ENV=production tsx build-dts.ts",
    "test": "cross-env NODE_ENV=testing jest --coverage",
    "clean": "cross-env rimraf miniprogram_dist/* .coverage-report/*",
    "preversion": "pnpm clean && pnpm build && pnpm test"
  },
  "dependencies": {
    "@doraemon-ui/miniprogram.core-js": "workspace:*",
    "@doraemon-ui/miniprogram.shared": "workspace:*",
    "@doraemon-ui/style": "workspace:*"
  },
  "devDependencies": {
    "@doraemon-ui/miniprogram.cli": "^0.0.2-alpha.64",
    "@doraemon-ui/miniprogram.tools": "0.0.2-alpha.41",
    "@types/node": "^25.5.2",
    "cross-env": "^7.0.3",
    "jest": "^30.3.0",
    "rimraf": "^3.0.2",
    "tsx": "^4.21.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
